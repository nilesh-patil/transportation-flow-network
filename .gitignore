# Raw TLC parquet (~2 GB) - never commit. Regenerate via `pixi run download`.
data/raw/

# Intermediate ingest caches (resumable; regenerated by `pixi run ingest`)
data/processed/_partial/
data/processed/_duckdb_tmp/

# Pixi environment (the lockfile is committed; the installed env is not)
.pixi/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/

# Scratch
*.tmp
*.log
